{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Wit",
  "version": "0.1.0",
  "identifier": "com.wit-term.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Wit",
        "width": 1024,
        "height": 768,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../completions/*",
      "../themes/*",
      "../shell-integration/*"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Context-aware terminal emulator",
    "longDescription": "Wit is a context-aware terminal emulator that detects project environments and provides intelligent completions without AI, cloud, or telemetry.",
    "copyright": "Copyright (c) 2025 Wit Terminal Contributors",
    "license": "MPL-2.0",
    "licenseFile": "../LICENSE.md",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {}
}
